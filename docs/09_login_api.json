        "get_cookies_json() → 序列化 cookies 为 JSON"
      ],
      "compat_function": "login_pdd_scan(timeout, on_status) → 与 login_pdd() 返回格式一致"
    },
    "playwright_login": {
      "file": "Channel/pinduoduo/pdd_login.py",
      "class": "PDDLogin",
      "methods": [
        "login() → 账号密码登录（Playwright）",
        "send_sms_code() → 发送短信验证码",
        "login_with_sms() → 短信验证码登录",
        "refresh_cookies() → 刷新 cookies（无头模式）"
      ],
      "compat_function": "login_pdd(name, password) → 账号密码登录入口"
    },
    "shared_apis": {
      "get_user_info": "Channel/pinduoduo/utils/API/get_user_info.py → POST /janus/api/new/userinfo",
      "get_shop_info": "Channel/pinduoduo/utils/API/get_shop_info.py → POST /earth/api/merchant/queryMerchantInfoByMallId",
