  "code_files": {
    "scan_login": {
      "file": "Channel/pinduoduo/pdd_scan_login.py",
      "class": "PDDScanLogin",
      "methods": [
        "get_qrcode() → 获取二维码 URL",
        "query_scan_status() → 查询扫码状态（单次）",
