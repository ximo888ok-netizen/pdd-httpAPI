  "core_endpoints_summary": {
    "scan_login_core": [
      {
        "endpoint": "POST /janus/api/scan/login/qrcode",
        "role": "获取登录二维码 URL",
        "required_fields": ["fingerprint"],
        "code_function": "PDDScanLogin.get_qrcode()"
      },
      {
        "endpoint": "POST /janus/api/scan/login/query",
        "role": "轮询扫码状态 (status: 1→等待 / 2→已扫 / 3→成功)",
        "required_fields": ["data (ticket)", "fingerprint"],
        "code_function": "PDDScanLogin.query_scan_status() / wait_for_scan()"
      },
      {
        "endpoint": "POST /janus/api/subSystem/getAuthToken",
        "role": "登录成功后获取子系统认证 Token",
        "required_fields": [],
        "code_function": "PDDScanLogin.get_auth_token()"
      }
    ],
    "fraud_detection": [
      {
        "endpoint": "POST https://xg.pinduoduo.com/xg/pfb/a2",
        "role": "浏览器指纹+行为数据加密上报",
        "note": "约 10KB base64 数据，含屏幕分辨率/devicePixelRatio/Canvas/UA 等"
      },
      {
        "endpoint": "GET https://xg.pinduoduo.com/xg/pfb/b",
        "role": "获取风控检测结果"
      }
    ],
    "post_login_init": [
      { "endpoint": "POST /janus/api/new/userinfo", "role": "获取用户信息 (user_id, mall_id, username)", "code_function": "GetUserInfo.get_user_info()" },
      { "endpoint": "GET /earth/api/mallInfo/commonMallInfo", "role": "店铺基本信息" },
      { "endpoint": "GET /earth/api/merchant/queryMerchantInfoByMallId", "role": "获取店铺信息 (mallId, mallName, mallLogo)", "code_function": "GetShopInfo.get_shop_info()" },
      { "endpoint": "POST /janus/api/subSystem/getAuthToken", "role": "子系统认证 Token" },
      { "endpoint": "POST /space/user/login", "role": "用户空间登录确认" },
      { "endpoint": "GET /earth/api/merchant/importNewStatus", "role": "商家入驻状态" },
      { "endpoint": "GET /antis/api/refundAddress/getDefaultRefundAddress", "role": "默认退货地址" },
      { "endpoint": "POST /janus/api/user/server/connect", "role": "用户服务连接" },
      { "endpoint": "POST /janus/api/userinfo", "role": "用户详细信息" },
      { "endpoint": "GET /janus/api/queryPasswordEncrypt", "role": "密码加密配置（账号密码登录用）" },
      { "endpoint": "POST /janus/api/checkLogin", "role": "登录状态校验（活动报名前探针也用此端点）" }
    ]
  },

  "auth_flow": {
    "description": "登录成功后认证 Token 的传递链路",
    "steps": [
      "#344 login/query (status=3) → 返回 userInfoVO { id, mallId, username } + Cookie 写入 session",
      "#350 subSystem/getAuthToken → 获取各业务子系统独立认证 Token",
      "#508 space/user/login → 用户空间登录确认",
      "#431 queryUserPermissionByUserId → 加载完整权限列表 (50+ 权限项)"
    ],
    "cookie_auth": "后续所有 API 请求携带 Cookie 中的 api_uid + rckk 进行鉴权",
    "note": "登录成功不返回 token，通过 Cookie 传递 session 标识"
  },

  "fingerprint_fields": {
    "description": "fingerprint 对象用于反爬验证，可构造固定值，不需要真实浏览器",
    "fields": {
      "innerHeight": "int - 视口高度 (752)",
      "innerWidth": "int - 视口宽度 (1179)",
      "devicePixelRatio": "float - 设备像素比 (1.5)",
      "availHeight": "int - 屏幕可用高度 (1040)",
      "availWidth": "int - 屏幕可用宽度 (1920)",
      "height": "int - 屏幕高度 (1080)",
      "width": "int - 屏幕宽度 (1920)",
      "colorDepth": "int - 颜色深度 (24)",
      "locationHref": "string - 当前页面 URL",
      "clientWidth": "int - 客户区宽度 (1179)",
      "clientHeight": "int - 客户区高度 (752)",
      "navigator.hardwareConcurrency": "int - CPU 核心数 (8)",
      "navigator.language": "string - 语言 (zh-CN)",
      "navigator.platform": "string - 平台 (Win32)",
      "navigator.cookieEnabled": "bool - Cookie 是否启用 (true)",
      "navigator.ua": "string - User-Agent"
    },
    "code_location": "Channel/pinduoduo/pdd_scan_login.py: PDDScanLogin._build_fingerprint()"
  },

