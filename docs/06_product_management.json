        {
          "name": "获取商品详情",
          "function": "get_product_detail()",
          "method": "POST",
          "url": "https://mms.pinduoduo.com/glide/v2/mms/query/commit/on_shop/detail",
          "source_file": "product_manager.py",
          "source_line": 136,
          "request_body": {
