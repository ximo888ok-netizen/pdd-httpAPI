        {
          "name": "列出图片文件",
          "function": "list_image_files()",
          "method": "POST",
          "url": "https://mms.pinduoduo.com/garner/mms/file/list",
          "source_line": 402,
          "request_body": {
            "dir_id": "int - 目录 ID",
            "page": "int - 页码",
            "page_size": "int - 每页数量"
          },
          "purpose": "列出目录下图片文件"
        },
        {
          "name": "生成图片缩略图/裁剪",
          "function": "make_image_thumbnail()",
          "method": "POST",
          "url": "https://mms.pinduoduo.com/glide/v2/mms/image/thumbnail",
          "source_line": 431,
          "request_body": {
            "url": "string - 原图 URL",
            "width": "int - 目标宽度（默认0）",
            "height": "int - 目标高度（默认0）",
            "if_cut": "bool - 是否裁剪（默认false）",
            "dx": "int - 裁剪偏移X（默认0）",
            "dy": "int - 裁剪偏移Y（默认0）"
          },
          "response": {
            "thumb_url": "string - 缩略图 URL"
          },
          "purpose": "生成图片缩略图/裁剪（包装标签图需要）"
        }
      ]
