    {
      "group": "类目查询（GET）",
      "items": [
        {
          "name": "搜索类目",
          "function": "search_categories()",
          "method": "GET",
          "url": "https://mms.pinduoduo.com/vodka/v2/mms/search/categories/v2?keyword={keyword}",
          "source_line": 547,
          "query_params": {
            "keyword": "string - 搜索关键词，如'面'、'收纳盒'"
          },
          "purpose": "按关键词搜索商品类目"
        },
        {
          "name": "获取类目详情",
          "function": "get_category_detail()",
          "method": "GET",
          "url": "https://mms.pinduoduo.com/vodka/v2/mms/category/detail?catId={cat_id}",
          "source_line": 567,
          "query_params": {
            "catId": "int - 类目 ID"
          },
          "response": {
            "cat_ids": "array[int] - 四级类目 ID 数组（如 [6630, 6689, 23965, 24027]）",
            "cats": "array[string] - 类目名称路径"
          },
          "purpose": "获取类目层级路径（cat_ids + cats）"
        },
        {
          "name": "获取子类目列表",
          "function": "get_category_children()",
          "method": "GET",
          "url": "https://mms.pinduoduo.com/vodka/v2/mms/categories?parentId={parent_id}",
          "source_line": 583,
          "query_params": {
            "parentId": "int - 父类目 ID"
          },
          "purpose": "获取子类目列表"
        },
        {
          "name": "获取一级类目列表",
          "function": "get_level1_categories()",
          "method": "GET",
          "url": "https://mms.pinduoduo.com/vodka/v2/mms/cat1List",
          "source_line": 596,
          "query_params": {},
          "purpose": "获取所有一级类目"
        }
      ]
    },
    {
      "group": "商品创建/编辑（POST）",
      "items": [
        {
          "name": "创建商品草稿",
          "function": "create_draft()",
          "method": "POST",
          "url": "https://mms.pinduoduo.com/glide/v2/mms/edit/commit/create_new",
          "source_line": 174,
          "referer": "https://mms.pinduoduo.com/goods/category",
          "request_body": {
            "cat_id": "int - 四级叶子类目 ID"
          },
          "response": {
            "goods_commit_id": "string - 提交草稿 ID",
            "goods_id": "int - 商品 ID"
          },
          "purpose": "创建商品草稿，获取后续操作所需的 ID（★ 创建流程入口）"
        },
        {
          "name": "保存商品草稿",
          "function": "save_draft()",
          "method": "POST",
          "url": "https://mms.pinduoduo.com/glide/mms/goodsCommit/action/edit",
          "source_line": 521,
          "referer": "https://mms.pinduoduo.com/goods/goods_add/index?id={goods_commit_id}&goods_id={goods_id}",
          "request_body": "完整商品数据（100+ 字段，详见 07_product_create_required_fields.json）",
          "purpose": "提交完整商品数据保存草稿（★★ 最核心端点）"
        },
        {
          "name": "保存 SPU 关键属性",
          "function": "save_spu_key_properties()",
          "method": "POST",
          "url": "https://mms.pinduoduo.com/glide/mms/goodsCommit/action/edit_spu_key_properties",
          "source_line": 332,
          "referer": "https://mms.pinduoduo.com/goods/goods_add/index?id={goods_commit_id}&goods_id={goods_id}",
          "request_body": {
            "goods_commit_id": "int - 提交草稿 ID",
            "goods_id": "int - 商品 ID",
            "key_properties": "array[object] - SPU 属性列表，每项含 {key, value, id}"
          },
          "purpose": "保存 SPU 关键属性（部分类目要求，如品牌、产地等）"
        },
        {
          "name": "获取草稿详情",
          "function": "get_draft_detail()",
          "method": "POST",
          "url": "https://mms.pinduoduo.com/glide/v2/mms/query/commit/detail",
          "source_line": 754,
          "request_body": {
            "goods_commit_id": "string - 提交草稿 ID"
          },
          "purpose": "获取已保存草稿的完整数据"
        }
      ]
    },
    {
      "group": "商品模板与规则（POST）",
      "items": [
        {
          "name": "获取发布模板",
          "function": "get_publish_template()",
          "method": "POST",
          "url": "https://mms.pinduoduo.com/draco-ms/mms/template/mall",
          "source_line": 626,
          "request_body": {
            "cat_id": "int",
            "goods_commit_id": "string (可选)",
            "goods_id": "int (可选)"
          },
          "purpose": "获取商品发布模板（属性、规格定义）"
        },
        {
          "name": "获取发布规则限制",
          "function": "get_publish_rules()",
          "method": "POST",
          "url": "https://mms.pinduoduo.com/glide/v2/mms/query/rules/limit/new",
          "source_line": 714,
          "request_body": {
            "cat_id": "int"
          },
          "purpose": "获取发布规则限制（价格范围、发货时间等）"
        },
        {
          "name": "获取已审核品牌列表",
          "function": "get_brand_list()",
          "method": "POST",
          "url": "https://mms.pinduoduo.com/draco-ms/mms/brand/audit/record",
          "source_line": 732,
          "request_body": {
            "cat_id": "int",
            "keyword": "string (可选)"
          },
          "purpose": "获取该类目下已审核的品牌列表"
        }
      ]
    },
    {
      "group": "规格管理（POST）",
      "items": [
        {
          "name": "获取规格类型列表",
          "function": "query_spec_names()",
          "method": "POST",
          "url": "https://mms.pinduoduo.com/glide/v2/mms/query/spec/name/list",
          "source_line": 653,
          "request_body": {
            "cat_id": "int"
          },
          "response": {
            "specs": [
              {
                "label": "string - 规格名（如'款式'）",
                "id": "int - 规格类型 ID"
              }
            ]
          },
          "purpose": "获取类目下可用规格类型（款式/尺寸/颜色）"
        },
        {
          "name": "按名称查询/创建规格值",
          "function": "create_spec_value()",
          "method": "POST",
          "url": "https://mms.pinduoduo.com/glide/v2/mms/query/spec/by/name",
          "source_line": 692,
          "request_body": {
            "parent_id": "int - 规格类型 ID",
            "name": "string - 规格值名称",
            "cat_id": "int - 类目 ID"
          },
          "response": {
            "spec_id": "int - 规格值 ID"
          },
          "purpose": "按名称查询或创建规格值，返回 spec_id（自定义规格必须先注册）"
        }
      ]
    },
    {
      "group": "图片上传（POST，三步流程）",
      "items": [
        {
          "name": "获取上传签名",
          "function": "_get_upload_signature()",
          "method": "POST",
          "url": "https://mms.pinduoduo.com/galerie/business/get_signature",
          "source_line": 207,
          "request_body": {
            "bucket_tag": "string - 默认 'mms-goods-image'"
          },
          "response": {
            "signature": "string"
          },
          "purpose": "获取图片上传签名"
        },
        {
          "name": "获取上传服务器地址",
          "function": "_get_upload_endpoint()",
          "method": "POST",
          "url": "https://file.pinduoduo.com/api/galerie/get_endpoint",
          "source_line": 231,
          "request_body": {
            "bucket_tag": "string - 默认 'mms-goods-image'"
          },
          "response": {
            "endpoint": "string - 上传服务器域名"
          },
          "purpose": "获取图片上传服务器地址"
        },
        {
          "name": "上传图片文件",
          "function": "upload_image()",
          "method": "POST",
          "url": "https://{endpoint}/v3/store_image",
          "source_line": 281,
          "request_body": "multipart/form-data - 图片文件二进制",
          "response": {
            "url": "string - 拼多多图床 URL（pfs.pinduoduo.com）"
          },
          "purpose": "上传图片到拼多多图床"
        }
      ]
    },
    {
      "group": "图片空间管理（POST）",
      "items": [
        {
          "name": "列出图片空间目录",
          "function": "list_image_dirs()",
