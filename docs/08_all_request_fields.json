{
  "title": "拼多多 HTTP API 全部接口请求体字段汇总",
  "description": "所有接口的完整请求体字段定义，按业务域分组",
  "base_url": "https://mms.pinduoduo.com",
  "auth": "所有请求自动携带 cookies + anti-content 头（由 anti_content.py 动态生成）",

  "01_认证与店铺信息": {
    "POST /chats/getToken": {
      "function": "get_token()",
      "request_body": {},
      "response": {"token": "string"}
    },
    "POST /janus/api/new/userinfo": {
      "function": "get_user_info()",
      "request_body": {},
      "response": {"user_id": "string", "username": "string", "mall_id": "string"}
    },
    "POST /earth/api/merchant/queryMerchantInfoByMallId": {
      "function": "get_shop_info()",
      "request_body": {},
      "response": {"mallId": "string", "mallName": "string", "mallLogo": "string"}
    },
    "POST /plateau/chat/set_csstatus": {
      "function": "set_csstatus()",
      "request_body": {"status": "int - 在线状态（1=上线, 0=离线）"},
      "response": {"success": "bool"}
    }
  },

  "02_客服消息": {
    "POST /plateau/chat/send_message (文本)": {
      "function": "send_text()",
      "request_body": {
        "data": {
          "cmd": "send_message",
          "request_id": "int - 毫秒时间戳",
          "message": {
            "to": {"role": "user", "uid": "string - 接收用户 UID"},
            "from": {"role": "mall_cs"},
            "content": "string - 文本内容",
            "msg_id": "null",
            "type": "int - 消息类型（0=文本）",
            "is_aut": "int - 是否自动回复（0=手动）",
            "manual_reply": "int - 手动回复标记（1=手动）"
          }
        },
        "client": "WEB"
      }
    },
    "POST /plateau/chat/send_message (图片)": {
      "function": "send_image()",
      "request_body": {
        "data": {
          "cmd": "send_message",
          "request_id": "int - 毫秒时间戳",
          "message": {
            "to": {"role": "user", "uid": "string - 接收用户 UID"},
            "from": {"role": "mall_cs"},
            "content": "string - 图片 URL",
            "msg_id": "null",
            "chat_type": "cs",
            "type": "int - 消息类型（1=图片）",
            "is_aut": "int - 是否自动回复",
            "manual_reply": "int - 手动回复标记"
          }
        },
        "client": "WEB"
      }
    },
    "POST /plateau/message/send/mallGoodsCard": {
      "function": "send_mallGoodsCard()",
      "request_body": {
        "uid": "string - 接收用户 UID",
        "goods_id": "int - 商品 ID",
        "biz_type": "int - 业务类型（2=客服推荐商品）"
      },
      "special_headers": {
        "anti-content": "动态生成",
        "referer": "https://mms.pinduoduo.com/chat-merchant/index.html"
      }
    },
    "POST /latitude/assign/getAssignCsList": {
      "function": "getAssignCsList()",
      "request_body": {"wechatCheck": true}
    },
    "POST /plateau/chat/move_conversation": {
      "function": "move_conversation()",
      "request_body": {
        "data": {
          "cmd": "move_conversation",
          "request_id": "int - 毫秒时间戳",
          "conversation": {
            "csid": "string - 目标客服 UID",
            "uid": "string - 用户 UID",
            "need_wx": false,
            "remark": "string - 转接备注（默认'无原因直接转移'）"
          }
        },
        "client": "WEB"
      }
    }
  },

  "03_数据中心": {
    "POST /sydney/api/mallTrade/queryMallTradeList": {
      "function": "query_trade_list()",
      "request_body": {"queryType": "int - 查询类型（6=实时交易趋势）", "queryDate": "string - 查询日期（空=默认）"}
    },
    "POST /sydney/api/mallScore/queryMallScoreInfo": {
      "function": "query_mall_score()",
      "request_body": {}
    },
    "POST /sydney/api/saleQuality/querySaleQualityDetailInfo": {
      "function": "query_sale_quality()",
      "request_body": {"queryDate": "string - 查询日期"}
    },
    "POST /sydney/api/mallTrade/getMallNotPayOrderInfoV2": {
      "function": "query_not_pay_order()",
      "request_body": {}
    },
    "POST /sydney/api/mallCoreData/homePageOverView": {
      "function": "query_home_overview()",
      "request_body": {},
      "referer": "https://mms.pinduoduo.com/home"
    },
    "POST /sydney/api/mallCoreData/homePagePromotionOverView": {
      "function": "query_home_promotion_overview()",
      "request_body": {},
      "referer": "https://mms.pinduoduo.com/home"
    }
  },

  "04_评价管理": {
    "POST /saturn/reviews/list": {
      "function": "get_reviews_list()",
      "request_body": {
        "startTime": "int|null - 开始时间（秒级时间戳）",
        "endTime": "int|null - 结束时间（秒级时间戳）",
        "pageNo": "int - 页码（默认1）",
        "pageSize": "int - 每页条数（默认10）",
        "orderSn": "string - 订单号筛选（可空）",
        "descScore": "array[string]|null - 评分筛选（['1']差评, ['2']中评, ['3']好评）"
      }
    },
    "POST /saturn/reviews/type/agg": {
      "function": "get_reviews_type_agg()",
      "request_body": {"rangeType": "int - 时间范围类型（4=近3个月）"}
    },
    "POST /saturn/reviews/keywords/agg": {
      "function": "get_reviews_keywords_agg()",
      "request_body": {
        "startTime": "int|null - 开始时间",
        "endTime": "int|null - 结束时间",
        "rangeType": "int - 时间范围类型（4=近3个月）"
      }
    },
    "POST /saturn/reviews/detail/info": {
      "function": "get_review_detail()",
      "request_body": {"reviewId": "string - 评价 ID", "goodsId": "string - 商品 ID"}
    },
    "POST /saturn/reportedReview/edit/createReportedReview": {
      "function": "create_reported_review()",
      "request_body": {
        "reviewId": "string - 评价 ID",
        "reportType": "string - 举报类型（8=疑似同行恶意竞争）",
        "pictureUrls": "array[string] - 举报图片 URL 列表",
        "describes": "string - 举报描述"
      }
    },
    "POST /saturn/reportedReview/query/queryTypesReportedReviewNum": {
      "function": "query_reported_review_num()",
      "request_body": {}
    }
  },

  "05_活动报名": {
    "POST /janus/api/checkLogin": {
      "function": "start() 探针",
      "request_body": {}
    },
    "POST /leekmms/activity/query/detail": {
      "function": "get_activity_detail()",
      "request_body": {"activity_id": "int - 活动 ID", "query_source": "int - 查询来源（1）"}
    },
    "POST /leekmms/activity/query/eligible/goods/listV2": {
      "function": "get_eligible_goods()",
      "request_body": {
        "activity_id": "int - 活动 ID",
        "goods_id": "int - 商品 ID",
        "goods_name": "string - 商品名称筛选（可空）",
        "page_number": "int - 页码（1）",
        "eligible": "int - 是否可报名（1）",
        "page_size": "int - 每页条数（10）"
      }
    },
    "POST /leekmms/activity/query/enroll/rule_v3": {
      "function": "get_price_rules()",
      "request_body": {"activity_id": "int - 活动 ID", "goods_id_list": "array[int] - 商品 ID 列表"}
    },
    "POST /leekmms/activity/query/enroll/rule_suggest_price": {
      "function": "get_suggest_prices()",
      "request_body": {
        "activity_id": "int - 活动 ID",
        "goods_id_list": "array[int] - 商品 ID 列表",
        "source_type": "string - 来源类型（'PROMO-HomeModule'）"
      }
    },
    "POST /lakemms/enrollV2": {
      "function": "_do_enroll_impl()",
      "request_body": {
        "activity_id": "int - 活动 ID",
        "goods_volist": "array - 报名商品列表，每项含 goods_id, enroll_rule_param, sku_price_list 等"
      },
      "retry_strategies": {
        "30001_建议价更新": "更新建议价后重新构建 body 重试（599行）",
        "30001_per_goods": "逐个商品单独报名重试（634行）",
        "2002690_库存超限": "去掉库存参数重试（665行）"
      }
    }
  },

  "06_商品管理_查询类": {
    "GET /vodka/v2/mms/search/categories/v2": {
