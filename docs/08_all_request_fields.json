  "09_商品管理_创建与编辑": {
    "POST /glide/v2/mms/edit/commit/create_new": {
      "function": "create_draft()",
      "request_body": {"cat_id": "int - 四级叶子类目 ID"},
      "response": {"goods_commit_id": "string - 草稿 ID", "goods_id": "int - 商品 ID"},
      "referer": "https://mms.pinduoduo.com/goods/category"
    },
    "POST /glide/mms/goodsCommit/action/edit": {
      "function": "save_draft()",
      "request_body": "完整商品数据（约100+字段），详见 07_product_create_required_fields.json",
      "auto_appended_fields": ["goods_commit_id", "goods_id", "cat_id", "crawlerInfo", "validate_message", "validate_message_v2"],
      "referer": "https://mms.pinduoduo.com/goods/goods_add/index?id={goods_commit_id}&goods_id={goods_id}"
    },
    "POST /glide/mms/goodsCommit/action/edit_spu_key_properties": {
      "function": "save_spu_key_properties()",
      "request_body": {"goods_commit_id": "string - 草稿 ID", "spu_properties": "array - SPU 关键属性列表"}
    },
    "POST /japi/goods/listing": {
      "function": "set_listing_status(online=True)",
      "request_body": {"goods_ids": "array[int] - 商品 ID 列表"},
      "status": "⚠️ TODO: 需抓包确认"
    },
    "POST /japi/goods/offline": {
      "function": "set_listing_status(online=False)",
      "request_body": {"goods_ids": "array[int] - 商品 ID 列表"},
      "status": "⚠️ TODO: 需抓包确认"
    },
    "POST /japi/goods/delete": {
      "function": "delete_products()",
      "request_body": {"goods_ids": "array[int] - 商品 ID 列表"},
      "status": "⚠️ TODO: 需抓包确认"
    }
  },

  "10_通用请求头": {
    "description": "所有请求通过 base_request.py 的 _build_headers() 自动构建",
    "headers": {
      "accept": "application/json, text/plain, */*",
      "accept-language": "zh-CN,zh;q=0.9,en;q=0.8",
      "anti-content": "由 anti_content.py 通过 execjs 调用 res.js 动态生成",
      "content-type": "application/json;charset=UTF-8",
      "origin": "https://mms.pinduoduo.com",
      "referer": "根据接口不同设置对应来源页",
      "user-agent": "DEFAULT_USER_AGENT 常量"
    },
    "cookies": "自动携带登录流程获取的完整 cookies 字典",
    "retry": "_execute_with_retry() 内置重试机制"
  }
}
