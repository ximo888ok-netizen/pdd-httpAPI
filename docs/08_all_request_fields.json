  "07_商品管理_图片类": {
    "POST /galerie/business/get_signature": {
      "function": "_get_upload_signature()",
      "request_body": {"bucket_tag": "string - bucket 标签（默认 'mms-goods-image'）"}
    },
    "POST file.pinduoduo.com/api/galerie/get_endpoint": {
      "function": "_get_upload_endpoint()",
      "request_body": {"bucket_tag": "string - bucket 标签"}
    },
    "POST https://{endpoint}/v3/store_image": {
      "function": "upload_image()",
      "request_body": "multipart/form-data - 图片文件二进制数据",
      "response": {"url": "string - pfs.pinduoduo.com 图片 URL"}
    },
    "POST /glide/v2/mms/image/thumbnail": {
      "function": "make_image_thumbnail()",
      "request_body": {"url": "string - 原图 URL", "width": "int - 目标宽度", "height": "int - 目标高度"}
    },
    "POST /garner/mms/dir/dirListV2": {
      "function": "list_image_dirs()",
      "request_body": {"parent_dir_id": "int - 父目录 ID（0=根目录）"}
